# TMDB API Configuration (Get yours at https://www.themoviedb.org/)
TMDB_API_KEY=your_tmdb_api_key_here
ACCESS_TOKEN=your_tmdb_bearer_access_token_here

# Firebase Client Configuration (NEXT_PUBLIC_ prefix makes it accessible to the browser)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_firebase_measurement_id

# Firebase Admin SDK Configuration (Server-Side Only)
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_firebase_project_id.iam.gserviceaccount.com
# Private key should include quotes and preserve literal \n characters (e.g. "-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...")
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_content_here\n-----END PRIVATE KEY-----\n"

# Email SMTP Settings (For OTP mailing, Server-Side Only)
EMAIL_USER=your_gmail_address_here@gmail.com
EMAIL_PASSWORD=your_gmail_app_password_here

# App URL (used to build absolute links in emails — no trailing slash)
# Development: http://localhost:3000
# Production:  https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
